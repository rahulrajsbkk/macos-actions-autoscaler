# GitHub Actions Autoscaling Runner Configuration
# Copy this to .env and fill in your values

# GitHub org or repo URL where the scale set will be registered
GITHUB_URL=https://github.com/YOUR_ORG

# Scale set name (this becomes your `runs-on:` label in workflows)
SCALE_SET_NAME=mac-mini-runners

# Maximum concurrent runners (tune based on CPU cores / workload)
MAX_RUNNERS=4

# Minimum idle runners to keep warm (0 = pure just-in-time)
MIN_RUNNERS=0

# Path to the extracted GitHub Actions runner directory
RUNNER_DIR=$HOME/actions-runner

# --- Authentication (GitHub App recommended) ---

# GitHub App Client ID (find in app settings)
GITHUB_APP_CLIENT_ID=

# GitHub App Installation ID (from the URL after installing on your org)
GITHUB_APP_INSTALLATION_ID=

# Path to the GitHub App private key PEM file
GITHUB_APP_PRIVATE_KEY_PATH=$HOME/.secrets/github-app.pem

# --- OR use a Personal Access Token (not recommended) ---
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
